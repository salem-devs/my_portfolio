                    <a href="#contact" class="px-8 py-4 bg-white text-black font-black text-xl rounded-[2rem] border-2 border-black hover:-translate-y-1 transition-all">
                        Contact
                    </a>
                </div>
            </div>

        </div>
    </section>

    <!-- CV SECTION -->
